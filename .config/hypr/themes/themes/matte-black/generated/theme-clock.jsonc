{
    "clock": {
        "timezone": "Asia/Jakarta",
        "tooltip-format": "<tt>{calendar}</tt>",
        "format": "󰥔 {:%H:%M | %d %B %Y}",
        "calendar": {
          "mode": "year",
          "mode-mon-col": 3,
          "on-scroll": 1,
          "format": {
            "months": "<span color='#bebebe'><b>{}</b></span>",
            "days": "<span color='#D35F5F'><b>{}</b></span>",
            "weekdays": "<span color='#b91c1c'><b>{}</b></span>",
            "today": "<span color='#e68e0d'><b><u>{}</u></b></span>"
          }
        }
    }
}
