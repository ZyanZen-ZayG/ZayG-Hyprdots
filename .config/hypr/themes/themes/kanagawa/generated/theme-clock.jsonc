{
    "clock": {
        "timezone": "Asia/Jakarta",
        "tooltip-format": "<tt>{calendar}</tt>",
        "format": "󰥔 {:%H:%M | %d %B %Y}",
        "calendar": {
          "mode": "year",
          "mode-mon-col": 3,
          "on-scroll": 1,
          "format": {
            "months": "<span color='#dcd7ba'><b>{}</b></span>",
            "days": "<span color='#957fb8'><b>{}</b></span>",
            "weekdays": "<span color='#c0a36e'><b>{}</b></span>",
            "today": "<span color='#7e9cd8'><b><u>{}</u></b></span>"
          }
        }
    }
}
