# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]="#0B0C16"

# Main text color
theme[main_fg]="#ddf7ff"

# Title color for boxes
theme[title]="#ddf7ff"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#82FB9C"

# Background color of selected item in processes box
theme[selected_bg]="#6a6e95"

# Foreground color of selected item in processes box
theme[selected_fg]="#82FB9C"

# Color of inactive/disabled text
theme[inactive_fg]="#6a6e95"

# Color of text appearing on top of graphs, i.e uptime and current network graph scaling
theme[graph_text]="#ddf7ff"

# Background color of the percentage meters
theme[meter_bg]="#6a6e95"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#ddf7ff"

# CPU, Memory, Network, Proc box outline colors
theme[cpu_box]="#86a7df"
theme[mem_box]="#4fe88f"
theme[net_box]="#50f872"
theme[proc_box]="#82FB9C"

# Box divider line and small boxes line color
theme[div_line]="#6a6e95"

# Temperature graph color (Green -> Yellow -> Red)
theme[temp_start]="#4fe88f"
theme[temp_mid]="#50f7d4"
theme[temp_end]="#50f872"

# CPU graph colors (Teal -> Lavender)
theme[cpu_start]="#7cf8f7"
theme[cpu_mid]="#829dd4"
theme[cpu_end]="#86a7df"

# Mem/Disk free meter (Mauve -> Lavender -> Blue)
theme[free_start]="#86a7df"
theme[free_mid]="#829dd4"
theme[free_end]="#7cf8f7"

# Mem/Disk cached meter (Sapphire -> Lavender)
theme[cached_start]="#829dd4"
theme[cached_mid]="#7cf8f7"
theme[cached_end]="#86a7df"

# Mem/Disk available meter (Peach -> Red)
theme[available_start]="#50f7d4"
theme[available_mid]="#50f872"
theme[available_end]="#50f872"

# Mem/Disk used meter (Green -> Sky)
theme[used_start]="#4fe88f"
theme[used_mid]="#7cf8f7"
theme[used_end]="#829dd4"

# Download graph colors (Peach -> Red)
theme[download_start]="#50f7d4"
theme[download_mid]="#50f872"
theme[download_end]="#50f872"

# Upload graph colors (Green -> Sky)
theme[upload_start]="#4fe88f"
theme[upload_mid]="#7cf8f7"
theme[upload_end]="#829dd4"

# Process box color gradient for threads, mem and cpu usage (Sapphire -> Mauve)
theme[process_start]="#7cf8f7"
theme[process_mid]="#829dd4"
theme[process_end]="#86a7df"
